  <item nodeId="node-33">
    <command xml:space="preserve">south</command>
    <result xml:space="preserve">Prison Cell&#x000A;You are in a dimly lit cell in the lower decks of the ISS Andromeda. The metal walls are cold and damp. To the north lies a dark corridor.&#x000A;&#x000A;You can see a rusty pipe here.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
