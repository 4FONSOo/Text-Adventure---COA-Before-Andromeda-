  <item nodeId="node-303">
    <command xml:space="preserve">read</command>
    <result xml:space="preserve">(Zarb)&#x000A;You are Zarb. You can sense emotional signals from others through weak telepathy.&#x000A;&#x000A;&gt;</result>
