  <item nodeId="node-297">
    <command xml:space="preserve">look</command>
    <result xml:space="preserve">Bioluminescent Forest&#x000A;A vast glowing forest where bioluminescent plants illuminate the silence. The world feels peaceful and untouched.&#x000A;&#x000A;You can see Zarb here.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-298"/>
    </children>
  </item>
