  <item nodeId="node-208">
    <command xml:space="preserve">go down</command>
    <result xml:space="preserve">Underground Tunnels&#x000A;Natural tunnels illuminated by faint bioluminescent flora.&#x000A;&#x000A;You can see a Bioluminescent Plant here.&#x000A;&#x000A;You enter the underground tunnels illuminated by natural bioluminescent life.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-209"/>
    </children>
  </item>
  <item nodeId="node-209">
    <command xml:space="preserve">go up</command>
    <result xml:space="preserve">Ghanrion Camp&#x000A;A peaceful tribal settlement built among living vegetation.&#x000A;&#x000A;You can see Vael here.&#x000A;&#x000A;You emerge near the camp.&#x000A;&#x000A;Human forces have surrounded the camp. Elder Vael stands before their commander. You must decide quickly: act, guide, or observe.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-210"/>
    </children>
  </item>
