  </item>
  <item nodeId="node-212">
    <command xml:space="preserve">go s</command>
    <result xml:space="preserve">Bioluminescent Forest&#x000A;A vast glowing forest where bioluminescent plants illuminate the silence. The world feels peaceful and untouched. You must explore de world around you. Or you can just stay freeze and don't play this awsome text adventure&#x000A;&#x000A;You can see Zarb here.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
      <child nodeId="node-213"/>
    </children>
  </item>
