  <item nodeId="node-3">
    <command xml:space="preserve">north</command>
    <result xml:space="preserve">Corridor&#x000A;A narrow maintenance corridor. Pipes run along the ceiling. You can hear voices to the east, and the hum of the engine room to the west.&#x000A;&#x000A;&gt;</result>
    <commentary xml:space="preserve"></commentary>
    <changed>NO</changed>
    <children>
